{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ferrum",
  "version": "0.1.0",
  "identifier": "com.simoon.ferrum",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ferrum",
        "width": 1200,
        "height": 800,
        "visible": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true,
        "backgroundColor": "#f3f3f3",
        "additionalBrowserArgs": "--disable-features=msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost img: http://img.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost http://asset.localhost https://asset.localhost http://img.localhost https://img.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
